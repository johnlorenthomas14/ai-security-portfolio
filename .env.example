# Copy to .env and fill in. Do not commit .env.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides. Defaults are set per-project.
# CLAUDE_MODEL=claude-sonnet-4-5
# CLAUDE_FAST_MODEL=claude-haiku-4-5

# Optional: forward detection events to Splunk HEC
# SPLUNK_HEC_URL=https://splunk.example.com:8088/services/collector/event
# SPLUNK_HEC_TOKEN=
# SPLUNK_HEC_INDEX=aisec
# SPLUNK_HEC_VERIFY_TLS=true
